{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "cronSchedule": "0 0 * * *",
    "startCommand": "python mava_sync.py"
  },
  "environments": {
    "production": {
      "variables": {
        "LOG_LEVEL": "INFO",
        "PAGE_SIZE": "50",
        "MAVA_API_KEY": "",
        "MAVA_BASE_URL": "https://api.mava.com",
        "SUPABASE_URL": "",
        "SUPABASE_KEY": "",
        "SUPABASE_HOST": ""
      }
    }
  }
} 
